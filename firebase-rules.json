{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": true,
        "participants": {
          "$uid": {
            ".write": "!data.exists() || data.child('uid').val() === $uid",
            ".validate": "newData.hasChildren(['name','uid','joinedAt']) && newData.child('uid').val() === $uid && newData.child('name').val().length > 0 && newData.child('name').val().length <= 64"
          }
        },
        "signaling": {
          "$slot": {
            "offer": {
              ".write": true,
              ".validate": "newData.hasChild('sdp')"
            },
            "answer": {
              ".write": true,
              ".validate": "newData.hasChild('sdp')"
            },
            "offerCandidates": {
              ".write": true
            },
            "answerCandidates": {
              ".write": true
            }
          }
        }
      }
    }
  }
}
